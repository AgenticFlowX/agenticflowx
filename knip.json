{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [
    "apps/workbench/src/components/coming-soon.tsx",
    "apps/workbench/src/lib/documents.ts",
    "apps/workbench/src/lib/pipeline.ts"
  ],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    "apps/chat": {
      "ignoreDependencies": ["tailwindcss"]
    },
    "apps/workbench": {
      "ignoreDependencies": ["tailwindcss", "react-resizable-panels"]
    },
    "apps/vscode-e2e": {
      "entry": [".vscode-test.mjs", "src/**/*.test.ts"],
      "ignoreDependencies": ["@vscode/test-electron"]
    },
    "packages/ui": {
      "ignoreDependencies": []
    },
    "packages/transport": {
      "ignoreDependencies": []
    },
    "packages/agent/pi-sdk": {
      "ignoreDependencies": ["@earendil-works/pi-agent-core", "@earendil-works/pi-tui"]
    }
  }
}
