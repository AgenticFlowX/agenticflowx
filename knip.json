{
	"$schema": "https://unpkg.com/knip@latest/schema.json",
	"ignore": [
		"**/__tests__/**",
		"apps/vscode-e2e/**",
		"apps/vscode/extension/api.ts",
		"apps/vscode/activate/**",
		"apps/vscode/workers/countTokens.ts",
		"apps/vscode/extension.ts",
		"scripts/**",
		"apps/cli/scripts/**",
		"apps/web-agenticflowx/next-sitemap.config.cjs"
	],
	"workspaces": {
		"apps/vscode": {
			"entry": ["extension.ts"],
			"project": ["**/*.ts"]
		},
		"apps/webview": {
			"entry": ["src/index.tsx"],
			"project": ["src/**/*.{ts,tsx}", "../vscode/shared/*.ts"]
		},
		"packages/{build,cloud,evals,ipc,telemetry,types}": {
			"project": ["src/**/*.ts"]
		},
		"apps/webview-panel": {
			"entry": ["src/panel.tsx"],
			"project": ["src/**/*.{ts,tsx}"]
		}
	}
}
