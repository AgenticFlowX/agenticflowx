.turbo/

# Build outputs
apps/*/dist/
apps/vscode/out/
apps/vscode-e2e/out/
apps/vscode-e2e/.vscode-test/

# Intermediate Pi SDK bundle; the shipped VS Code copy lives under
# apps/vscode/resources/pi-sdk/ and is regenerated by prepare:pi-sdk.
packages/agent/pi-sdk/dist/
apps/vscode/resources/pi-sdk/

# Package-local turbo logs/cache
apps/*/.turbo/
packages/*/.turbo/

# TypeScript incremental artifacts
*.tsbuildinfo

# Dev loop bridge files
.vite-port-chat
.vite-port-workbench

# Coverage reports
coverage/
**/coverage/

# Release artifacts
*.vsix

# Local dev artifacts (screenshots, profiling). Kept at repo root so they sit
# outside any app source tree and don't get picked up by app builds.
artifacts/

