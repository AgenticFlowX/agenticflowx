# pnpm configuration — engine-strict refuses install on wrong Node/pnpm version.
# Pairs with package.json `engines` and .nvmrc.
# @see docs/specs/430-dx-enforcement/430-dx-enforcement.md [FR-25] [DES-WORKSPACE]

engine-strict=true

# pnpm 10 disables npm-style pre/post lifecycle scripts by default.
# apps/vscode relies on `prepackage` (chat + workbench builds, prepare:webviews,
# prepare:pi-sdk, host esbuild) and `pretest` (prepare:pi-sdk) — re-enable so
# `pnpm build:vsix` and `pnpm test` pick up latest changes instead of stale output.
enable-pre-post-scripts=true
