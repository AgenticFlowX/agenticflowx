{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (watch — HMR)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/apps/vscode"],
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/apps/vscode/out/**/*.js"],
      "preLaunchTask": "watch:extension-dev",
      "env": {
        "NODE_ENV": "development"
      },
      "resolveSourceMapLocations": ["${workspaceFolder}/**", "!**/node_modules/**"]
    },
    {
      "name": "Run Extension (build — one-shot)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/apps/vscode"],
      "outFiles": ["${workspaceFolder}/apps/vscode/out/**/*.js"],
      "preLaunchTask": "build:extension-dev",
      "sourceMaps": true
    }
  ]
}
