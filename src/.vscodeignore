# Exclude everything
**

# Include README.md, CHANGELOG.md and LICENSE
!README.md
!CHANGELOG.md
!LICENSE

# Include package.json
!package.json
!package.nls.*

# Include the built extension (exclude source maps)
!dist/**/*.js
!dist/**/*.wasm
!dist/**/*.node
!dist/i18n/**

# Include the built webview
!webapp-core/audio
!webapp-core/build/assets/*.js
!webapp-core/build/assets/*.ttf
!webapp-core/build/assets/*.css
!webapp-core/build/assets/fonts/*.woff
!webapp-core/build/assets/fonts/*.woff2
!webapp-core/build/assets/fonts/*.ttf

# Include default themes JSON files used in getTheme
!integrations/theme/default-themes/**

# Include icons and images
!assets/codicons/**
!assets/vscode-material-icons/**
!assets/icons/**
!assets/images/**

# Exclude source maps and env
# (no !**/*.map — strip source maps from VSIX)
# (no !.env — no telemetry)
