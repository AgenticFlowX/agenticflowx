          "group": "1_chat@5",
          "when": "editorLangId != markdown"
        },
        {
          "command": "afx.action.generateTests",
          "group": "1_chat@6",
          "when": "editorLangId != markdown"
        },
        {
          "command": "afx.action.addSeeLink",
