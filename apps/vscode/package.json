    "keybindings": [
      {
        "command": "afx.openSidebar",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus"
      },
      {
        "command": "afx.setMode",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "afx.setIntent",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "dev": "node esbuild.mjs --watch",
    "sync:skills": "node ./scripts/sync-skills.mjs",
    "prepare:webviews": "node ./scripts/prepare-webviews.mjs",
    "prepare:pi-sdk": "pnpm --filter @afx/agent-pi-sdk build && node ./scripts/prepare-pi-sdk.mjs",
    "prepackage": "cp ../../README.md ./README.md && cp ../../CHANGELOG.md ./CHANGELOG.md && pnpm --filter apps/chat build && pnpm --filter apps/workbench build && pnpm run prepare:webviews && pnpm run prepare:pi-sdk && pnpm run build",
    "check-types": "tsc --noEmit",
    "watch:tsc": "tsc --noEmit --watch",
    "pretest": "pnpm run prepare:pi-sdk",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "package": "pnpm vsce package --out ../../bin/ --no-dependencies"
  },
  "dependencies": {
    "@afx/shared": "workspace:*",
    "@afx/parsers": "workspace:*",
    "@afx/agent-pi": "workspace:*",
    "@afx/agent-pi-sdk": "workspace:*",
    "@types/vscode": "^1.120.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6"
  }
}
