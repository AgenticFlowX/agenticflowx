        {
          "command": "afx.action.adrReview",
          "group": "7_adr@1",
          "when": "resource =~ /\\/docs\\/adr\\// || resourceFilename =~ /^adr-.*\\.md$/ || resourceFilename =~ /^ADR-.*\\.md$/"
        },
        {
          "command": "afx.action.adrList",
          "group": "7_adr@2",
