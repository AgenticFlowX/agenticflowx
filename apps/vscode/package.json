      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "afx.editorContext",
          "group": "navigation@1"
        }
      ],
      "editor/title": [
        {
          "submenu": "afx.editorContext",
          "group": "navigation@9",
          "when": "afx.isSprint || resourceFilename == spec.md || resourceFilename == design.md || resourceFilename == tasks.md || resourceFilename == journal.md || resource =~ /\\/docs\\/(adr|research)\\// || resource =~ /\\/docs\\/specs\\/.*\\/research\\//"
        }
      ],
      "afx.editorContext": [
        {
          "command": "afx.action.saveToNotes",
          "group": "0_notes@1"
        },
        {
          "command": "afx.action.addToContext",
          "group": "1_chat@1"
        },
