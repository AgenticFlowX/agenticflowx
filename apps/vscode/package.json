  "contributes": {
    "configuration": {
      "title": "AgenticFlowX",
      "properties": {
        "afx.rpc.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable the Pi CLI RPC runtime. Disabled by default so API Providers can run without spawning a local Pi process."
        },
        "afx.agentBinaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to the configured agent CLI binary. Leave empty to use the adapter default."
        },
        "afx.agentEphemeralSession": {
          "type": "boolean",
          "default": false,
          "description": "Run the configured agent with --no-session (ephemeral). Leave disabled to enable session continuity across runtimes."
        },
        "afx.sessionDir": {
          "type": "string",
          "default": "",
          "description": "Directory for persisted agent sessions. Leave empty to use extension-managed storage."
        },
        "afx.sdk.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Use API Providers when an API key is configured."
        },
        "afx.sdk.defaultModel": {
          "type": "string",
          "default": "anthropic:claude-opus-4-5",
          "description": "Default model for API Providers. Format: <provider>:<modelId>."
        },
        "afx.sdk.ollamaBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL for a local Ollama server. Leave empty to disable."
        },
        "afx.context.includeActiveFileContext": {
          "type": "boolean",
          "default": true,
          "description": "Attach the active editor file to new chat turns and keep the chat composer toggle in sync with this default."
        },
        "afx.mode.active": {
          "type": "string",
          "enum": [
            "code",
            "explore",
            "spec"
          ],
          "default": "code",
          "description": "Default mode for the chat composer. Code is full-access; Explore is read-only; Spec is planning-only (docs and specs only). Saved globally unless this workspace has an override."
        },
        "afx.composer.intent.slot": {
          "type": "number",
          "enum": [
            1,
            2,
            3,
            4
          ],
          "default": 1,
          "description": "Composer Intent slot. 1 = Default, 2 = Ask, 3 = Architect, 4 = Code in Code mode or PRD in Explore mode."
        },
        "afx.composer.intent.minimized": {
          "type": "boolean",
          "default": false,
          "description": "Minimize the Composer Intent strip to a one-line chip."
        },
        "afx.debugPerf": {
          "type": "boolean",
          "default": false,
          "description": "Show streaming performance diagnostics in the chat status bar."
        },
        "afx.theme": {
          "type": "string",
          "enum": [
            "meridian"
          ],
          "default": "meridian",
          "description": "UI identity/accent theme for the AgenticFlowX sidebar and workbench panels. Meridian is the AgenticFlowX identity."
        },
        "afx.style": {
          "type": "string",
          "enum": [
            "lyra",
            "luma",
            "maia",
            "nova",
            "vega",
            "mira",
            "sera"
          ],
          "default": "lyra",
          "description": "UI style treatment for the AgenticFlowX sidebar and workbench panels. Lyra is the compact baseline."
        },
        "afx.logLevel": {
          "type": "string",
          "enum": [
            "silent",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "default": "info",
          "description": "AgenticFlowX log verbosity for the AgenticFlowX output channel. Override at runtime with the AFX_LOG_LEVEL environment variable."
        },
        "afx.telemetry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable anonymous UI analytics for AgenticFlowX webviews. On by default; respects VS Code telemetry and Do Not Track.",
          "tags": [
            "telemetry",
            "usesOnlineServices"
          ]
        }
      }
    },
