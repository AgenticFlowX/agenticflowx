{
	"name": "agenticflowx",
	"displayName": "AgenticFlowX",
	"description": "The spec-driven AI coding environment.",
	"publisher": "agenticflowx",
	"version": "1.0.5",
	"icon": "assets/icons/icon.png",
	"galleryBanner": {
		"color": "#617A91",
		"theme": "dark"
	},
	"engines": {
		"vscode": "^1.84.0",
		"node": "20.19.2"
	},
	"author": {
		"name": "AgenticFlowX"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/AgenticFlowX/agenticflowx"
	},
	"homepage": "https://github.com/AgenticFlowX/agenticflowx",
	"telemetry": {
		"url": "https://clarity.ms"
	},
	"categories": [
		"AI",
		"Chat",
		"Programming Languages",
		"Snippets",
		"Machine Learning",
		"Other"
	],
	"keywords": [
		"agenticflowx",
		"afx",
		"spec",
		"ai-coding",
		"spec-driven",
		"traceability",
		"multi-agent",
		"ai-agent",
		"code-quality",
		"development-workflow",
		"copilot",
		"ai-assistant",
		"automation",
		"project-management",
		"requirements",
		"code-tracing",
		"agentic",
		"prompt-engineering",
		"chat-participant",
		"agents",
		"ai",
		"ai agents",
		"artificial intelligence",
		"assistant",
		"autocomplete",
		"c#",
		"c++",
		"chat",
		"code completion",
		"coding assistant",
		"css",
		"go",
		"html",
		"intellisense",
		"java",
		"javascript",
		"keybindings",
		"mcp",
		"node.js",
		"pair programming",
		"php",
		"python",
		"react",
		"remote agents",
		"ruby",
		"rust",
		"swift",
		"typescript"
	],
	"activationEvents": [
		"onLanguage",
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"chatParticipants": [
			{
				"id": "agenticflowx.chat",
				"name": "afx",
				"fullName": "AgenticFlowX",
				"description": "Spec-driven development — task status, spec context, traceability",
				"isSticky": false,
				"commands": [
					{
						"name": "status",
						"description": "Show project feature overview with task progress"
					},
					{
						"name": "next",
						"description": "Show the next unchecked task with spec context"
					},
					{
						"name": "spec",
						"description": "Show spec content for a feature"
					}
				]
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "agenticflowx-ActivityBar",
					"title": "%views.activitybar.title%",
					"icon": "assets/icons/icon.svg"
				}
			],
			"panel": [
				{
					"id": "agenticflowx-panel",
					"title": "AgenticFlowX",
					"icon": "assets/icons/icon.svg"
				}
			]
		},
		"views": {
			"agenticflowx-ActivityBar": [
				{
					"type": "webview",
					"id": "agenticflowx.SidebarProvider",
					"name": "%views.sidebar.name%"
				}
			],
			"agenticflowx-panel": [
				{
					"type": "webview",
					"id": "agenticflowx.panel",
					"name": "AgenticFlowX",
					"when": "agenticflowx.panelAvailable"
				}
			]
		},
		"commands": [
			{
				"command": "agenticflowx.plusButtonClicked",
				"title": "%command.newTask.title%",
				"icon": "$(edit)"
			},
			{
				"command": "agenticflowx.historyButtonClicked",
				"title": "%command.history.title%",
				"icon": "$(history)"
			},
			{
				"command": "agenticflowx.marketplaceButtonClicked",
				"title": "%command.marketplace.title%",
				"icon": "$(extensions)"
			},
			{
				"command": "agenticflowx.popoutButtonClicked",
				"title": "%command.openInEditor.title%",
				"icon": "$(link-external)"
			},
			{
				"command": "agenticflowx.settingsButtonClicked",
				"title": "%command.settings.title%",
				"icon": "$(settings-gear)"
			},
			{
				"command": "agenticflowx.openInNewTab",
				"title": "%command.openInNewTab.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "agenticflowx.explainCode",
				"title": "%command.explainCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "agenticflowx.fixCode",
				"title": "%command.fixCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "agenticflowx.improveCode",
				"title": "%command.improveCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "agenticflowx.addToContext",
				"title": "%command.addToContext.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "agenticflowx.newTask",
				"title": "%command.newTask.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "agenticflowx.terminalAddToContext",
				"title": "%command.terminal.addToContext.title%",
				"category": "Terminal"
			},
			{
				"command": "agenticflowx.terminalFixCommand",
				"title": "%command.terminal.fixCommand.title%",
				"category": "Terminal"
			},
			{
				"command": "agenticflowx.terminalExplainCommand",
				"title": "%command.terminal.explainCommand.title%",
				"category": "Terminal"
			},
			{
				"command": "agenticflowx.setCustomStoragePath",
				"title": "%command.setCustomStoragePath.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "agenticflowx.importSettings",
				"title": "%command.importSettings.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "agenticflowx.focusInput",
				"title": "%command.focusInput.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "agenticflowx.acceptInput",
				"title": "%command.acceptInput.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "agenticflowx.toggleAutoApprove",
				"title": "%command.toggleAutoApprove.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "agenticflowx.afxVerifySpec",
				"title": "Verify with AFX Spec",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxCheckTrace",
				"title": "Check @see Traceability",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxAddSeeLink",
				"title": "Add @see Link",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxReviewSpec",
				"title": "Review Spec",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxValidateSpec",
				"title": "Validate Structure",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxApproveSpec",
				"title": "Approve Spec",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxReviewDesign",
				"title": "Review Design",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxDiscussSection",
				"title": "Discuss Section",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxReviewProgress",
				"title": "Review Progress",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxPickNextTask",
				"title": "Pick Next Task",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxPromoteToAdr",
				"title": "Promote to ADR",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxSummarizeSession",
				"title": "Summarize Session",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxDispatchCopilot",
				"title": "Code in Copilot Chat",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxDispatchAgenticFlowX",
				"title": "Code in AgenticFlowX",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxDispatchClaudePanel",
				"title": "Code in Claude Code (Panel)",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxDispatchClaudeSidebar",
				"title": "Code in Claude Code (Copilot Chat)",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxDispatchClaudeTerminal",
				"title": "Code in Claude Code (Terminal)",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxDispatchCodexPanel",
				"title": "Code in OpenAI Codex (Editor Tab)",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxDispatchCodexSidebar",
				"title": "Code in OpenAI Codex (Sidebar)",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxDispatchCodexThread",
				"title": "Code in OpenAI Codex (Add to Thread)",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxDispatchCodexTerminal",
				"title": "Code in OpenAI Codex (Terminal)",
				"category": "AgenticFlowX"
			},
			{
				"command": "agenticflowx.afxDispatchGemini",
				"title": "Code in Gemini Code Assist",
				"category": "AgenticFlowX"
			}
		],
		"menus": {
			"editor/context": [
				{
					"submenu": "agenticflowx.contextMenu",
					"group": "1"
				}
			],
			"agenticflowx.contextMenu": [
				{
					"command": "agenticflowx.addToContext",
					"group": "1_actions@1"
				},
				{
					"command": "agenticflowx.explainCode",
					"group": "1_actions@2"
				},
				{
					"command": "agenticflowx.improveCode",
					"group": "1_actions@3"
				},
				{
					"command": "agenticflowx.afxVerifySpec",
					"group": "2_afx@1",
					"when": "agenticflowx.loaded"
				},
				{
					"command": "agenticflowx.afxCheckTrace",
					"group": "2_afx@2",
					"when": "agenticflowx.loaded"
				},
				{
					"command": "agenticflowx.afxAddSeeLink",
					"group": "2_afx@3",
					"when": "agenticflowx.loaded"
				},
				{
					"command": "agenticflowx.afxReviewSpec",
					"group": "3_afxSpec@1",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/spec\\.md$/"
				},
				{
					"command": "agenticflowx.afxValidateSpec",
					"group": "3_afxSpec@2",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/spec\\.md$/"
				},
				{
					"command": "agenticflowx.afxApproveSpec",
					"group": "3_afxSpec@3",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/spec\\.md$/"
				},
				{
					"command": "agenticflowx.afxReviewDesign",
					"group": "3_afxSpec@1",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/design\\.md$/"
				},
				{
					"command": "agenticflowx.afxDiscussSection",
					"group": "3_afxSpec@2",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/(design|spec|tasks|journal)\\.md$/"
				},
				{
					"command": "agenticflowx.afxReviewProgress",
					"group": "3_afxSpec@1",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/tasks\\.md$/"
				},
				{
					"command": "agenticflowx.afxPickNextTask",
					"group": "3_afxSpec@2",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/tasks\\.md$/"
				},
				{
					"command": "agenticflowx.afxPromoteToAdr",
					"group": "3_afxSpec@1",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/journal\\.md$/"
				},
				{
					"command": "agenticflowx.afxSummarizeSession",
					"group": "3_afxSpec@2",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/journal\\.md$/"
				},
				{
					"command": "agenticflowx.afxDispatchCopilot",
					"group": "4_afxDispatch@1",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/tasks\\.md$/"
				},
				{
					"command": "agenticflowx.afxDispatchAgenticFlowX",
					"group": "4_afxDispatch@2",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/tasks\\.md$/"
				},
				{
					"command": "agenticflowx.afxDispatchClaudePanel",
					"group": "4_afxDispatch@3",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/tasks\\.md$/"
				},
				{
					"command": "agenticflowx.afxDispatchClaudeSidebar",
					"group": "4_afxDispatch@4",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/tasks\\.md$/"
				},
				{
					"command": "agenticflowx.afxDispatchClaudeTerminal",
					"group": "4_afxDispatch@5",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/tasks\\.md$/"
				},
				{
					"command": "agenticflowx.afxDispatchCodexPanel",
					"group": "4_afxDispatch@6",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/tasks\\.md$/"
				},
				{
					"command": "agenticflowx.afxDispatchCodexSidebar",
					"group": "4_afxDispatch@7",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/tasks\\.md$/"
				},
				{
					"command": "agenticflowx.afxDispatchCodexThread",
					"group": "4_afxDispatch@8",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/tasks\\.md$/"
				},
				{
					"command": "agenticflowx.afxDispatchCodexTerminal",
					"group": "4_afxDispatch@9",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/tasks\\.md$/"
				},
				{
					"command": "agenticflowx.afxDispatchGemini",
					"group": "4_afxDispatch@7",
					"when": "agenticflowx.loaded && resourcePath =~ /docs\\/specs\\/.*\\/tasks\\.md$/"
				}
			],
			"terminal/context": [
				{
					"submenu": "agenticflowx.terminalMenu",
					"group": "2"
				}
			],
			"agenticflowx.terminalMenu": [
				{
					"command": "agenticflowx.terminalAddToContext",
					"group": "1_actions@1"
				},
				{
					"command": "agenticflowx.terminalFixCommand",
					"group": "1_actions@2"
				},
				{
					"command": "agenticflowx.terminalExplainCommand",
					"group": "1_actions@3"
				}
			],
			"view/title": [
				{
					"command": "agenticflowx.plusButtonClicked",
					"group": "navigation@1",
					"when": "view == agenticflowx.SidebarProvider"
				},
				{
					"command": "agenticflowx.settingsButtonClicked",
					"group": "navigation@2",
					"when": "view == agenticflowx.SidebarProvider"
				},
				{
					"command": "agenticflowx.marketplaceButtonClicked",
					"group": "navigation@3",
					"when": "view == agenticflowx.SidebarProvider"
				},
				{
					"command": "agenticflowx.historyButtonClicked",
					"group": "overflow@1",
					"when": "view == agenticflowx.SidebarProvider"
				},
				{
					"command": "agenticflowx.popoutButtonClicked",
					"group": "overflow@2",
					"when": "view == agenticflowx.SidebarProvider"
				}
			],
			"editor/title": [
				{
					"command": "agenticflowx.plusButtonClicked",
					"group": "navigation@1",
					"when": "activeWebviewPanelId == agenticflowx.TabPanelProvider"
				},
				{
					"command": "agenticflowx.settingsButtonClicked",
					"group": "navigation@2",
					"when": "activeWebviewPanelId == agenticflowx.TabPanelProvider"
				},
				{
					"command": "agenticflowx.marketplaceButtonClicked",
					"group": "navigation@3",
					"when": "activeWebviewPanelId == agenticflowx.TabPanelProvider"
				},
				{
					"command": "agenticflowx.historyButtonClicked",
					"group": "overflow@1",
					"when": "activeWebviewPanelId == agenticflowx.TabPanelProvider"
				},
				{
					"command": "agenticflowx.popoutButtonClicked",
					"group": "overflow@2",
					"when": "activeWebviewPanelId == agenticflowx.TabPanelProvider"
				}
			]
		},
		"keybindings": [
			{
				"command": "agenticflowx.addToContext",
				"key": "cmd+k cmd+a",
				"mac": "cmd+k cmd+a",
				"win": "ctrl+k ctrl+a",
				"linux": "ctrl+k ctrl+a",
				"when": "editorTextFocus && editorHasSelection"
			},
			{
				"command": "agenticflowx.toggleAutoApprove",
				"key": "cmd+alt+a",
				"mac": "cmd+alt+a",
				"win": "ctrl+alt+a",
				"linux": "ctrl+alt+a"
			}
		],
		"submenus": [
			{
				"id": "agenticflowx.contextMenu",
				"label": "%views.contextMenu.label%"
			},
			{
				"id": "agenticflowx.terminalMenu",
				"label": "%views.terminalMenu.label%"
			}
		],
		"configuration": {
			"title": "%configuration.title%",
			"properties": {
				"agenticflowx.allowedCommands": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [
						"git log",
						"git diff",
						"git show"
					],
					"description": "%commands.allowedCommands.description%"
				},
				"agenticflowx.deniedCommands": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "%commands.deniedCommands.description%"
				},
				"agenticflowx.commandExecutionTimeout": {
					"type": "number",
					"default": 0,
					"minimum": 0,
					"maximum": 600,
					"description": "%commands.commandExecutionTimeout.description%"
				},
				"agenticflowx.commandTimeoutAllowlist": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "%commands.commandTimeoutAllowlist.description%"
				},
				"agenticflowx.preventCompletionWithOpenTodos": {
					"type": "boolean",
					"default": false,
					"description": "%commands.preventCompletionWithOpenTodos.description%"
				},
				"agenticflowx.vsCodeLmModelSelector": {
					"type": "object",
					"properties": {
						"vendor": {
							"type": "string",
							"description": "%settings.vsCodeLmModelSelector.vendor.description%"
						},
						"family": {
							"type": "string",
							"description": "%settings.vsCodeLmModelSelector.family.description%"
						}
					},
					"description": "%settings.vsCodeLmModelSelector.description%"
				},
				"agenticflowx.customStoragePath": {
					"type": "string",
					"default": "",
					"description": "%settings.customStoragePath.description%"
				},
				"agenticflowx.enableCodeActions": {
					"type": "boolean",
					"default": true,
					"description": "%settings.enableCodeActions.description%"
				},
				"agenticflowx.autoImportSettingsPath": {
					"type": "string",
					"default": "",
					"description": "%settings.autoImportSettingsPath.description%"
				},
				"agenticflowx.maximumIndexedFilesForFileSearch": {
					"type": "number",
					"default": 10000,
					"minimum": 5000,
					"maximum": 500000,
					"description": "%settings.maximumIndexedFilesForFileSearch.description%"
				},
				"agenticflowx.useAgentRules": {
					"type": "boolean",
					"default": true,
					"description": "%settings.useAgentRules.description%"
				},
				"agenticflowx.apiRequestTimeout": {
					"type": "number",
					"default": 600,
					"minimum": 0,
					"maximum": 3600,
					"description": "%settings.apiRequestTimeout.description%"
				},
				"agenticflowx.newTaskRequireTodos": {
					"type": "boolean",
					"default": false,
					"description": "%settings.newTaskRequireTodos.description%"
				},
				"agenticflowx.codeIndex.embeddingBatchSize": {
					"type": "number",
					"default": 60,
					"minimum": 1,
					"maximum": 200,
					"description": "%settings.codeIndex.embeddingBatchSize.description%"
				},
				"agenticflowx.debug": {
					"type": "boolean",
					"default": false,
					"description": "%settings.debug.description%"
				},
				"agenticflowx.debugProxy.enabled": {
					"type": "boolean",
					"default": false,
					"description": "%settings.debugProxy.enabled.description%",
					"markdownDescription": "%settings.debugProxy.enabled.description%"
				},
				"agenticflowx.debugProxy.serverUrl": {
					"type": "string",
					"default": "http://127.0.0.1:8888",
					"description": "%settings.debugProxy.serverUrl.description%",
					"markdownDescription": "%settings.debugProxy.serverUrl.description%"
				},
				"agenticflowx.debugProxy.tlsInsecure": {
					"type": "boolean",
					"default": false,
					"description": "%settings.debugProxy.tlsInsecure.description%",
					"markdownDescription": "%settings.debugProxy.tlsInsecure.description%"
				}
			}
		}
	},
	"scripts": {
		"lint": "eslint . --ext=ts --max-warnings=0",
		"check-types": "tsc --noEmit",
		"pretest": "turbo run bundle --cwd ..",
		"test": "vitest run",
		"format": "prettier --write .",
		"bundle": "node esbuild.mjs",
