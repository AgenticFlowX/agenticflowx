{
	"name": "@agenticflowx/cli",
	"version": "0.1.17",
	"description": "AgenticFlowX CLI - Run the AgenticFlowX agent from the command line",
	"private": true,
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"afx": "dist/index.js"
	},
	"scripts": {
		"format": "prettier --write 'src/**/*.ts'",
		"lint": "eslint src --ext .ts --max-warnings=0",
		"check-types": "tsc --noEmit",
		"test": "vitest run",
		"test:integration": "tsx scripts/integration/run.ts",
		"build": "tsup",
		"build:extension": "pnpm --filter agenticflowx bundle",
		"clean": "rimraf dist .turbo"
	},
	"dependencies": {
		"@agenticflowx/core": "workspace:^",
		"@agenticflowx/types": "workspace:^",
		"@agenticflowx/vscode-shim": "workspace:^",
		"@inkjs/ui": "^2.0.0",
		"@vscode/ripgrep": "^1.15.9",
		"commander": "^12.1.0",
		"cross-spawn": "^7.0.6",
		"execa": "^9.5.2",
		"fuzzysort": "^3.1.0",
		"ink": "^6.6.0",
		"p-wait-for": "^5.0.2",
		"react": "^19.1.0",
		"zustand": "^5.0.0"
	},
	"devDependencies": {
		"@agenticflowx/config-eslint": "workspace:^",
		"@agenticflowx/config-typescript": "workspace:^",
		"@types/node": "^24.1.0",
		"@types/react": "^19.1.6",
		"ink-testing-library": "^4.0.0",
		"rimraf": "^6.0.1",
		"tsup": "^8.4.0",
		"vitest": "^3.2.3"
	}
}
