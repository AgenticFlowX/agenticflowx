{
	"name": "@agenticflowx/webapp-panel",
	"private": true,
	"type": "module",
	"scripts": {
		"lint": "eslint src --ext=ts,tsx --max-warnings=0",
		"check-types": "echo 'Skipped: webapp-panel type-checks via vite build (cross-package aliases require bundler resolution)'",
