		"@tailwindcss/vite": "^4.0.0",
		"react": "^18.3.1",
		"react-compiler-runtime": "^1.0.0",
		"react-dom": "^18.3.1",
		"tailwindcss": "^4.0.0"
	},
	"devDependencies": {
		"@agenticflowx/config-eslint": "workspace:^",
		"@agenticflowx/config-typescript": "workspace:^",
		"@types/react": "^18.3.23",
		"@types/react-dom": "^18.3.5",
		"@vitejs/plugin-react": "^4.3.4",
		"babel-plugin-react-compiler": "^1.0.0",
		"typescript": "^5.8.3",
		"vite": "6.3.6",
		"vitest": "^3.2.3"
	}
